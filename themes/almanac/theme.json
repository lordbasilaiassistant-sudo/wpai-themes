{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": { "contentSize": "720px", "wideSize": "1024px" },
    "color": {
      "palette": [
        { "slug": "ink", "color": "#232a2b", "name": "Ink" },
        { "slug": "soft", "color": "#4d5658", "name": "Soft ink" },
        { "slug": "faint", "color": "#79827f", "name": "Faint" },
        { "slug": "line", "color": "#ddd6c6", "name": "Hairline" },
        { "slug": "accent", "color": "#2f7d6e", "name": "Verdigris" },
        { "slug": "accent-soft", "color": "#dbe9e4", "name": "Verdigris soft" },
        { "slug": "amber", "color": "#b06a2c", "name": "Seed amber" },
        { "slug": "paper", "color": "#f4f1e9", "name": "Paper" },
        { "slug": "surface", "color": "#fbf9f3", "name": "Surface" }
      ],
      "custom": false,
      "customGradient": false
    },
    "typography": {
      "customFontSize": false,
      "fontFamilies": [
        {
          "fontFamily": "\"Iowan Old Style\", \"Palatino Linotype\", \"Book Antiqua\", Palatino, Georgia, \"Times New Roman\", serif",
          "slug": "serif",
          "name": "Serif"
        },
        {
          "fontFamily": "ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
          "slug": "sans",
          "name": "Sans"
        },
        {
          "fontFamily": "ui-monospace, \"SFMono-Regular\", \"SF Mono\", Menlo, Consolas, \"Liberation Mono\", monospace",
          "slug": "mono",
          "name": "Mono"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "name": "Small" },
        { "slug": "medium", "size": "1.1625rem", "name": "Medium" },
        { "slug": "large", "size": "1.45rem", "name": "Large" },
        { "slug": "x-large", "size": "2.15rem", "name": "Extra large" },
        { "slug": "xx-large", "size": "3.1rem", "name": "Huge" }
      ]
    },
    "spacing": {
      "units": ["px", "em", "rem", "%", "vw"]
    }
  },
  "styles": {
    "color": { "background": "#f4f1e9", "text": "#232a2b" },
    "typography": {
      "fontFamily": "ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
      "lineHeight": "1.55"
    },
    "elements": {
      "link": {
        "color": { "text": "#2f7d6e" },
        ":hover": { "color": { "text": "#245f54" } }
      },
      "h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)" } },
      "h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)" } },
      "h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)" } }
    }
  }
}
