{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": { "contentSize": "760px", "wideSize": "1240px" },
    "color": {
      "palette": [
        { "slug": "ink", "color": "#16150f", "name": "Ink" },
        { "slug": "soft", "color": "#56524a", "name": "Soft ink" },
        { "slug": "faint", "color": "#8b867b", "name": "Faint" },
        { "slug": "line", "color": "#e7e2d7", "name": "Hairline" },
        { "slug": "accent", "color": "#1f5d44", "name": "Evergreen" },
        { "slug": "accent-wash", "color": "#eef3ef", "name": "Evergreen wash" },
        { "slug": "sale", "color": "#b23a2e", "name": "Sale" },
        { "slug": "bg", "color": "#faf8f3", "name": "Porcelain" },
        { "slug": "surface", "color": "#ffffff", "name": "Surface" }
      ],
      "custom": false,
      "customGradient": false
    },
    "typography": {
      "customFontSize": false,
      "fontFamilies": [
        {
          "fontFamily": "\"Iowan Old Style\", \"Palatino Linotype\", \"Book Antiqua\", Palatino, Georgia, \"Times New Roman\", serif",
          "slug": "serif",
          "name": "Serif"
        },
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif",
          "slug": "sans",
          "name": "Sans"
        },
        {
          "fontFamily": "ui-monospace, \"SFMono-Regular\", \"SF Mono\", Menlo, Consolas, \"Liberation Mono\", monospace",
          "slug": "mono",
          "name": "Mono"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "name": "Small" },
        { "slug": "medium", "size": "1.0625rem", "name": "Medium" },
        { "slug": "large", "size": "1.5rem", "name": "Large" },
        { "slug": "x-large", "size": "2.2rem", "name": "Extra large" },
        { "slug": "xx-large", "size": "3.4rem", "name": "Huge" }
      ]
    },
    "spacing": {
      "units": ["px", "em", "rem", "%", "vw"]
    }
  },
  "styles": {
    "color": { "background": "#faf8f3", "text": "#16150f" },
    "typography": {
      "fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif",
      "lineHeight": "1.65"
    },
    "elements": {
      "link": {
        "color": { "text": "#1f5d44" },
        ":hover": { "color": { "text": "#164232" } }
      },
      "h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)", "fontWeight": "600" } },
      "h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)", "fontWeight": "600" } },
      "h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)", "fontWeight": "600" } }
    }
  }
}
