{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": { "contentSize": "720px", "wideSize": "1024px" },
    "color": {
      "palette": [
        { "slug": "ink", "color": "#2a201a", "name": "Ink" },
        { "slug": "soft", "color": "#5d4d40", "name": "Soft ink" },
        { "slug": "faint", "color": "#8a7461", "name": "Faint" },
        { "slug": "line", "color": "#e6d6c0", "name": "Hairline" },
        { "slug": "accent", "color": "#c2541f", "name": "Terracotta" },
        { "slug": "accent-soft", "color": "#f3ddce", "name": "Terracotta soft" },
        { "slug": "olive", "color": "#5f6b3a", "name": "Herb olive" },
        { "slug": "olive-soft", "color": "#e3e7d4", "name": "Olive soft" },
        { "slug": "paper", "color": "#f6ede0", "name": "Cream" },
        { "slug": "surface", "color": "#fffaf2", "name": "Surface" }
      ],
      "custom": true,
      "customGradient": false
    },
    "typography": {
      "customFontSize": false,
      "fontFamilies": [
        {
          "fontFamily": "\"Hoefler Text\", \"Iowan Old Style\", \"Palatino Linotype\", \"Book Antiqua\", Palatino, Georgia, \"Times New Roman\", serif",
          "slug": "serif",
          "name": "Serif"
        },
        {
          "fontFamily": "\"Avenir Next\", \"Segoe UI\", ui-sans-serif, system-ui, -apple-system, Roboto, Helvetica, Arial, sans-serif",
          "slug": "sans",
          "name": "Sans"
        },
        {
          "fontFamily": "ui-monospace, \"SFMono-Regular\", \"SF Mono\", Menlo, Consolas, \"Liberation Mono\", monospace",
          "slug": "mono",
          "name": "Mono"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "name": "Small" },
        { "slug": "medium", "size": "1.1875rem", "name": "Medium" },
        { "slug": "large", "size": "1.55rem", "name": "Large" },
        { "slug": "x-large", "size": "2.4rem", "name": "Extra large" },
        { "slug": "xx-large", "size": "3.5rem", "name": "Huge" }
      ]
    },
    "spacing": {
      "units": ["px", "em", "rem", "%", "vw"]
    }
  },
  "styles": {
    "color": { "background": "#f6ede0", "text": "#2a201a" },
    "typography": {
      "fontFamily": "\"Avenir Next\", \"Segoe UI\", ui-sans-serif, system-ui, -apple-system, Roboto, Helvetica, Arial, sans-serif",
      "lineHeight": "1.55"
    },
    "elements": {
      "link": {
        "color": { "text": "#c2541f" },
        ":hover": { "color": { "text": "#97400f" } }
      },
      "h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)" } },
      "h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)" } },
      "h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)" } }
    }
  }
}
